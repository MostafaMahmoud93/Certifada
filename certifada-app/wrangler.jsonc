{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "certifada-app",
  "compatibility_date": "2026-07-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/Certifada/browser",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
